{
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.playwright*": true,
        "LICENSE": true,
        "*.*": true,
        "**/*.xlsx.meta.yaml": true,
        "**/.version": true,
        "NOTICE": true
    },
    "markdown.preview.openMarkdownLinks": "inEditor",
    "workbench.editorAssociations": {
        "*.md": "vscode.markdown.preview.editor"
    },
    "explorer.decorations.colors": true,
    "workbench.colorCustomizations": {
        "gitDecoration.ignoredResourceForeground": "#a5e8c2"
    }
    ,
    // set color theme to solarized dark
    "workbench.colorTheme": "Dusk Office Bay",
}
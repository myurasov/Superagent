# User-generated workspace data — never committed.
workspace/

# Development / temporary scratch
.tmp/
.tools/
__dev/
__workspace-*/

# Python
*.pyc
*.pyo
__pycache__/
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Export files (may contain workspace data)
superagent-export-*.json

# OS files
.DS_Store
Thumbs.db

# IDE — keep .vscode/settings.json tracked, ignore the rest
!.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Cursor — keep hooks + the project MCP template tracked, ignore the rest
# (including .cursor/mcp.json, which is the runtime file copied from the
# .cursor/mcp.json.cursor template by `init` and may carry auth tokens).
!.cursor/
.cursor/*
!.cursor/hooks.json
!.cursor/mcp.json.cursor

# Claude Code — keep project settings tracked; ignore per-machine local
# overrides (.claude/settings.local.json) and any other in-tree state.
!.claude/
.claude/*
!.claude/settings.json

# MCP project-level config — runtime files carry auth tokens and are never
# committed. The committed starting-point templates (one per IDE) live at:
#   .mcp.json.claude         → committed (Claude Code starting point)
#   .cursor/mcp.json.cursor  → committed (Cursor starting point; allow-listed above)
.mcp.json
!.mcp.json.claude

**/.playwright*
